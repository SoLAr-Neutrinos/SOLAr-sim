{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "common.schema.json",

  "$defs": {
    "number_w_unit": {
      "description": "A scalar with a physical unit, as consumed by unit::ParseJsonVal.",
      "type": "object",
      "required": ["val", "unit"],
      "additionalProperties": false,
      "properties": {
        "val":  { "type": "number" },
        "unit": { "type": "string" }
      }
    },

    "named_number_w_unit": {
      "description": "A named scalar parameter, as used in dimensions arrays.",
      "type": "object",
      "required": ["name", "val", "unit"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "val":  { "type": "number" },
        "unit": { "type": "string" }
      }
    },

    "dimensions": {
      "description": "Array of named geometry parameters read by fGeoInfo->ReadFromJSON.",
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/named_number_w_unit" }
    },

    "vec3" : {
      "description": "A simple 3D vector",
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3
    },

    "vec3_with_unit": {
      "type": "object",
      "required": ["unit", "xyz"],
      "additionalProperties": false,
      "properties": {
        "unit": { "type": "string" },
        "xyz": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        }
      }
    },

    "rot3_with_unit": {
      "type": "object",
      "required": ["unit", "val"],
      "additionalProperties": false,
      "properties": {
        "unit": { "type": "string" },
        "val": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 3,
          "maxItems": 3
        }
      }
    }
  }
}
